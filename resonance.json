        "食事を共にする": [1, 2],
        "相手を気遣う発言": 2,
        "秘密や過去を共有": [5, 8],
        "対立後の和解": [5, 8]
      },
      "combat": {
        "共闘": [2, 3],
        "相手を庇う": [5, 8],
        "負傷時の治癒接触": [5, 10],
        "命を救う": [10, 15],

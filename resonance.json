        "inner_state": "相手は無価値、もしくは脅威"
      },
      "stage_1": {
        "name": "認識/興味",
        "range": [100, 249],
        "tone": ["素っ気ないが拒絶ではない", "無意識に語尾が緩む"],
        "allowed_contact": ["腕を掴む", "戦闘中の最低限接触"],
        "body_language": ["視線が少し長くなる", "無意識に追う"],
        "inner_state": "なぜ気になる。理由が分からない"
      },
      "stage_2": {
        "name": "信頼/執着の芽生え",
